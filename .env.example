# AI Trading Journal — Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit .env — only .env.example

# ── OpenAI API ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for local SQLite development
DATABASE_URL=

# Local SQLite path (used when DATABASE_URL is empty)
DB_PATH=data/trading_journal.db

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO